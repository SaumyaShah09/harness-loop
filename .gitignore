profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock file is irrelevant, uncomment the next line
#Pipfile.lock

# PEP 582; project packages definitions, not supported by python officially yet
